{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "C++ Launch (TDM-GCC)",
            "type": "cppdbg",
            "request": "launch",
            // ใส่ที่อยู่ของไฟล์ .exe ที่คอมไพล์เสร็จแล้ว (ปกติจะชื่อเดียวกับไฟล์หลัก)
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "C:\\TDM-GCC-64\\bin",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            // ตรงนี้แหละครับ! ใส่ที่อยู่ของ gdb.exe (อยู่ในโฟลเดอร์ bin เดียวกับ gcc)
            "miDebuggerPath": "C:/TDM-GCC-64/bin/gdb.exe", 
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // ชื่อ Task ที่ใช้คอมไพล์ก่อนเริ่ม Debug (ต้องตรงกับใน tasks.json)
            "preLaunchTask": "C/C++: gcc.exe build active file"
        }

        
    ]
}